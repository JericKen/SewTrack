generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STAFF
}

enum ProductType {
  RESALE
  MANUFACTURED
  MATERIAL
}

enum PaymentMethod {
  CASH
  GCASH
  BANK_TRANSFER
}

enum SaleStatus {
  COMPLETED
  VOIDED
}

enum Unit {
  PCS
  METER
  PACK
  PAIR
  ROLL
  BUNDLE
}

enum StockTransactionType {
  IN
  OUT
  ADJUSTMENT
}

enum StockReason {
  INITIAL_STOCK
  PURCHASE
  SALE
  REPAIR_USED
  DAMAGED
  PERSONAL_USE
  ADJUSTMENT
  RETURN
}

enum StockReferenceType {
  PURCHASE
  SALE
  REPAIR
  ADJUSTMENT
} 

model User {
  id        Int      @id @default(autoincrement())

  name      String
  email     String   @unique
  password  String

  role      Role     @default(ADMIN)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id          Int      @id @default(autoincrement())

  code        String   @unique
  name        String   @unique
  description String?

  isActive    Boolean  @default(true)

  products    Product[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Product {
  id              Int      @id @default(autoincrement())

  categoryId      Int

  name            String
  description     String?

  sku             String   @unique
  barcode         String?  @unique

  type            ProductType

  costPrice       Decimal  @db.Decimal(10,2)
  sellingPrice    Decimal  @db.Decimal(10,2)
  
  purchaseItems      PurchaseItem[]

  stockTransactions  StockTransaction[]

  stockQuantity   Int      @default(0)
  minimumStock    Int      @default(5)

  saleItems SaleItem[]

  unit            Unit

  imageUrl        String?

  isActive        Boolean  @default(true)

  category         Category @relation(fields: [categoryId], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Supplier {
  id             Int      @id @default(autoincrement())

  name           String
  contactPerson  String?
  phone          String?
  email          String?
  address        String?
  remarks        String?

  isActive       Boolean  @default(true)

  purchases      Purchase[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Purchase {
  id             Int      @id @default(autoincrement())

  supplierId     Int?

  purchasedAt    DateTime @default(now())

  referenceNo    String?

  totalAmount    Decimal   @db.Decimal(10,2)

  remarks        String?

  supplier        Supplier? @relation(fields: [supplierId], references: [id])

  items           PurchaseItem[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model PurchaseItem {
  id          Int      @id @default(autoincrement())

  purchaseId  Int
  productId   Int

  quantity    Int

  unitCost    Decimal @db.Decimal(10,2)

  purchase    Purchase @relation(fields: [purchaseId], references: [id])

  product     Product @relation(fields: [productId], references: [id])
}

model StockTransaction {  
  id              Int      @id @default(autoincrement())

  productId       Int

  type            StockTransactionType

  reason          StockReason

  quantity        Int

  balanceAfter    Int

  referenceType   StockReferenceType?

  referenceId     Int?

  remarks         String?

  product         Product @relation(fields: [productId], references: [id])

  createdAt       DateTime @default(now())
}

model Sale {

  id            Int      @id @default(autoincrement())

  invoiceNo     String   @unique

  customerName  String?

  paymentMethod PaymentMethod

  status        SaleStatus @default(COMPLETED)

  totalAmount   Decimal @db.Decimal(10,2)

  remarks       String?

  items         SaleItem[]

  createdAt     DateTime @default(now())

}

model SaleItem {

  id         Int @id @default(autoincrement())

  saleId     Int

  productId  Int

  quantity   Int

  unitPrice  Decimal @db.Decimal(10,2)

  subtotal   Decimal @db.Decimal(10,2)

  sale        Sale    @relation(fields: [saleId], references: [id])

  product     Product @relation(fields: [productId], references: [id])

}

model CashSession {

  id Int @id @default(autoincrement())

  sessionDate DateTime @unique

  openingCash Decimal @db.Decimal(10,2)

  notes String?

  createdAt DateTime @default(now())

}